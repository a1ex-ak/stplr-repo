sfe_249_new_extractor=1

name=chromium-gost
version=148.0.7778.216
release=1
group="Networking/WWW"
summary="Chromium with GOST support from the official site (Stable Channel)"
architectures=('amd64')
homepage="https://github.com/deemru/chromium-gost/"
maintainer="Alexey Kamaev <a1exak@outlook.com>"
license=('Multiple, see https://chrome.google.com/')
appstream_app_id='Chromium-Gost'
nonfree=1
nonfree_url="https://github.com/deemru/chromium-gost/"

_channel=stable

sources=(
    "https://github.com/deemru/Chromium-Gost/releases/download/${version}/chromium-gost-${version}-linux-amd64.deb"
	"local:///eula_text.html"
)

checksums=(
	sha256:b46805c0e22c22bcbb5b853c3fcb58ca119beda3b0580d5bcc59806b41b23143
)

build_deps=(
	bsdtar
	binutils
)

auto_reqprov_method=dirty
auto_req=1
auto_prov=1

disable_network=1

prepare() {
	bsdtar -xf data.tar.xz -C "$pkgdir/"
}

package() {
	# Icons
	for i in 16x16 24x24 32x32 48x48 64x64 128x128 256x256; do
		install -Dm644 "$pkgdir"/opt/google/chrome/product_logo_${i/x*/}.png \
			"$pkgdir"/usr/share/icons/hicolor/$i/apps/google-chrome.png
	done

	# License
	install-license eula_text.html google-chrome-$_channel/eula_text.html
	install-license "$pkgdir"/opt/google/chrome/WidevineCdm/LICENSE \
		google-chrome-$_channel/WidevineCdm-LICENSE.txt

	# Fix the Chrome desktop entry
	sed -i \
		-e "/Exec=/i\StartupWMClass=Chromium-Gost" \
		-e "s/x-scheme-handler\/ftp;\?//g" \
		"$pkgdir"/usr/share/applications/chromium-gost.desktop

	# Remove the Debian Cron job, duplicate product logos and menu directory
	rm -r \
		"$pkgdir"/etc/cron.daily/ \
		"$pkgdir"/opt/google/chrome/cron/ \
		"$pkgdir"/opt/google/chrome/product_logo_*.png
}

files() {
	files-find-binary google-chrome-$_channel

	files-find-desktop \
		com.google.Chrome.desktop \
		google-chrome.desktop

	files-find-doc google-chrome-$_channel

	files-find \
		"/opt/google/**/*" \
		"/usr/share/appdata/*" \
		"/usr/share/gnome-control-center/default-apps/*" \
		"/usr/share/icons/hicolor/*/apps/*" \
		"/usr/share/licenses/**/*" \
		"/usr/share/man/man1/*"
}
